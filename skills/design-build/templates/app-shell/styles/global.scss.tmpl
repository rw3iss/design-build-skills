@use "variables" as *;
@use "mixins" as *;
@use "fonts" as *;
@use "mobile";

*, *::before, *::after { box-sizing: border-box; }
html, body, #root { height: 100%; margin: 0; }
body {
  background: $color-bg;
  color: $color-text;
  font-family: $font-body;
  font-size: 16px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
a { color: $color-primary; }
